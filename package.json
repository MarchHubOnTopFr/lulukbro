{
  "name": "synthia-api",
  "version": "4.0.0",
  "description": "Synthia — Luarmor-alternative HWID key system with script protection, audit logging, and admin dashboard",
  "main": "server.js",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start":      "NODE_ENV=production node server.js",
    "dev":        "NODE_ENV=development node --watch server.js",
    "cron":       "node cron.js",
    "admin":      "node admin.js",
    "pm2":        "pm2 start ecosystem.config.js",
    "pm2:logs":   "pm2 logs synthia-api"
  },
  "license": "ISC",
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet":             "^7.1.0",
    "joi":                "^17.13.3",
    "jsonwebtoken":       "^9.0.2",
    "morgan":             "^1.10.0",
    "pg":                 "^8.12.0",
    "uuid":               "^10.0.0"
  }
}
