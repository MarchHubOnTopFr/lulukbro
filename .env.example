# ══════════════════════════════════════════════════════════════════════════════
# Synthia .env — includes all HWID/fingerprint additions
# Copy to .env and fill in your values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=18635
NODE_ENV=production
PUBLIC_URL=https://your-domain.com
CORS_ORIGIN=*

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synthia
DB_USER=synthia_user
DB_PASSWORD=change_me_strong_password
DB_POOL_MAX=20
DB_POOL_MIN=2

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_minimum_32_random_characters_here
JWT_EXPIRY=7d

# ── Key limits ─────────────────────────────────────────────────────────────────
MAX_KEYS_PER_USER=10
HWID_RESET_COOLDOWN_HOURS=24

# ══════════════════════════════════════════════════════════════════════════════
# HWID Engine  (new — required for fingerprint.js and hwid.js)
# ══════════════════════════════════════════════════════════════════════════════

# Server-side secret for HMAC-SHA256 HWID derivation.
# Generate: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
# NEVER change this after binding keys — all bound HWIDs will become invalid.
HWID_SECRET=change_me_hwid_secret_40_chars_minimum_here

# Weighted score threshold for accepting a fingerprint match.
# Range: 0.0–1.0.  Recommended: 0.80 (desktop), 0.75 (mobile-heavy games).
# Lower = more lenient (fewer false-lockouts). Higher = stricter security.
HWID_ACCEPT_THRESHOLD=0.80

# Max Hamming distance allowed on clientId before it's treated as a mismatch.
# 0 = exact match only.  2–3 = tolerates minor executor/version noise.
MAX_CLIENTID_DRIFT=3

# Roblox Users API cache TTL in milliseconds (avoids hammering the external API).
ROBLOX_CACHE_TTL_MS=300000

# ── Anomaly detection ──────────────────────────────────────────────────────────
# Sliding window length (minutes) for the per-IP and per-userId rate limits.
ANOMALY_WINDOW_MIN=10

# Max verify attempts from a single IP within the window before blocking.
ANOMALY_IP_LIMIT=15

# Max verify attempts from a single Roblox userId within the window.
ANOMALY_UID_LIMIT=8

# ══════════════════════════════════════════════════════════════════════════════
# Get Key Flow  (new — required for routes/getkey.js)
# ══════════════════════════════════════════════════════════════════════════════

# The dashboard username that owns auto-generated keys.
# This user is created automatically with role='user' and no login password.
GETKEY_OWNER_USER=system

# Days until auto-generated keys expire.  Set to 0 for no expiry.
GETKEY_EXPIRES_DAYS=30

# Seconds the challenge token (from /getkey/start) remains valid.
# Must be longer than the UI countdown (5 s) + network latency.
GETKEY_TOKEN_TTL_S=90

# ── Maintenance / cron ─────────────────────────────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=90
CRON_INTERVAL_MS=21600000   # 6 hours

# ── Process monitor ────────────────────────────────────────────────────────────
MEMORY_THRESHOLD=85
UPTIME_LIMIT_HOURS=48
MONITOR_INTERVAL_MS=300000
